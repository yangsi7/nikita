{
  "granularity": "standard",
  "git": {
    "enabled": true,
    "branching_strategy": "phase",
    "branch_template": "gsd/phase-{phase}-{slug}"
  },
  "workflow": {
    "use_worktrees": true,
    "subagent_timeout": 300,
    "inline_plan_threshold": 2,
    "planning_commit_docs": true
  },
  "response_language": "en"
}
