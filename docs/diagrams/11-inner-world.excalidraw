    {"type":"text","id":"life_detail","x":35,"y":185,"width":230,"height":210,"text":"Generates daily events:\n\nWork\n  projects, deadlines, colleagues\n  \"Finished the security audit\"\n\nSocial\n  friends (Lena), plans, tension\n  \"Lena was distant today\"\n\nPersonal\n  gym, errands, mood events\n  \"Good workout, feeling strong\"\n\n\u2192 She references these naturally\n\u2192 Not scripted \u2014 simulated","originalText":"Generates daily events:\n\nWork\n  projects, deadlines, colleagues\n  \"Finished the security audit\"\n\nSocial\n  friends (Lena), plans, tension\n  \"Lena was distant today\"\n\nPersonal\n  gym, errands, mood events\n  \"Good workout, feeling strong\"\n\n\u2192 She references these naturally\n\u2192 Not scripted \u2014 simulated","fontSize":10,"fontFamily":1,"textAlign":"left","verticalAlign":"top","strokeColor":"#0f766e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":11034,"version":1,"versionNonce":11035,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

